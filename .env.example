# AI Provider (choose one or both)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Security (required for production)
WEEKLYAMP_SECRET_KEY=          # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEEKLYAMP_ADMIN_HASH=          # Generate with: weeklyamp security hash-password
WEEKLYAMP_ADMIN_PASSWORD=      # Alternative: plain password (hashed at runtime)

# Database
WEEKLYAMP_DB_PATH=data/weeklyamp.db
WEEKLYAMP_DB_BACKEND=sqlite                # "sqlite" or "postgres"
WEEKLYAMP_DATABASE_URL=                     # PostgreSQL connection string, e.g. postgresql://user:pass@localhost:5432/weeklyamp

# AI config
WEEKLYAMP_AI_PROVIDER=anthropic
WEEKLYAMP_AI_MODEL=claude-sonnet-4-5-20250929

# Email / SMTP (optional)
WEEKLYAMP_EMAIL_ENABLED=false
WEEKLYAMP_SMTP_HOST=
WEEKLYAMP_SMTP_PORT=587
WEEKLYAMP_SMTP_USER=
WEEKLYAMP_SMTP_PASSWORD=
WEEKLYAMP_EMAIL_FROM=
WEEKLYAMP_EMAIL_FROM_NAME=TrueFans NEWSLETTERS

# Submissions API
TRUEFANS_SUBMISSIONS_API_KEY=
